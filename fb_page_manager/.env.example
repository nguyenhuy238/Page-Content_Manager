# Facebook Page target
# PAGE_ID: ID của Facebook Page sẽ đăng bài (vd: 123456789012345)
PAGE_ID=

# ACCESS_TOKEN: Page Access Token (long-lived) có quyền đăng bài
ACCESS_TOKEN=

# Gemini AI
# GEMINI_API_KEY: API key từ aistudio.google.com
GEMINI_API_KEY=

# News source API
# NEWS_API_KEY: API key từ newsapi.org (có thể để trống nếu chỉ dùng RSS)
NEWS_API_KEY=

# RSS URLs
# Danh sách feed, ngăn cách bằng dấu phẩy
# Ví dụ: https://vnexpress.net/rss/tin-moi-nhat.rss,https://techcrunch.com/feed/
RSS_URLS=https://vnexpress.net/rss/tin-moi-nhat.rss,https://techcrunch.com/feed/

# Scheduler time slots (24h)
# Danh sách giờ đăng mỗi ngày, ngăn cách bằng dấu phẩy
# Ví dụ: 07:00,11:30,20:00
POSTING_TIMES=07:00,11:30,20:00

# Flask dashboard
# FLASK_PORT: cổng chạy web dashboard
FLASK_PORT=5000

# FLASK_DEBUG: true/false
FLASK_DEBUG=false

# Optional runtime settings
GEMINI_MODEL=gemini-1.5-flash
NEWS_KEYWORD=technology
NEWS_LANGUAGE=en
NEWS_PAGE_SIZE=10
DB_PATH=data/fb_page_manager.db
LOG_LEVEL=INFO

# ---- Mexico campaign automation ----
TARGET_LANGUAGE=es-MX
TARGET_COUNTRY=Mexico
TARGET_AUDIENCE=Audiencia mexicana interesada en celebridades y cronicas

# Nguon YouTube va URL bai viet de crawl (phan cach bang dau phay)
YOUTUBE_CHANNEL_URLS=
CUSTOM_NEWS_URLS=
YOUTUBE_MAX_VIDEOS_PER_CHANNEL=2
YOUTUBE_TRANSCRIPT_LANGS=es,en

# Batch size moi lan chay campaign
PIPELINE_BATCH_SIZE=4

# true = chi tao nhap va luu DB, khong post that
PIPELINE_DRY_RUN=true

# Bật/tat xuat ban tu dong
PIPELINE_AUTO_POST_FACEBOOK=false
PIPELINE_AUTO_POST_WORDPRESS=false
PIPELINE_AUTO_COMMENT_ON_FACEBOOK=true
FB_COMMENT_TEMPLATE=Lee la historia completa aqui: {url}

# WordPress REST API (Application Password)
WP_BASE_URL=
WP_USERNAME=
WP_APP_PASSWORD=
WP_POST_STATUS=draft
WP_DEFAULT_CATEGORY_ID=0
WP_DEFAULT_AUTHOR_ID=0

# OpenAI Image API (neu muon tao anh AI tu dong)
OPENAI_API_KEY=
AI_TEXT_PROVIDER=gemini
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1536
GENERATED_IMAGE_DIR=data/generated_images
