# Facebook Page target
# PAGE_ID: ID của Facebook Page sẽ đăng bài (vd: 123456789012345)
PAGE_ID=

# ACCESS_TOKEN: Page Access Token (long-lived) có quyền đăng bài
ACCESS_TOKEN=

# Claude AI
# CLAUDE_API_KEY: API key từ console.anthropic.com
CLAUDE_API_KEY=

# News source API
# NEWS_API_KEY: API key từ newsapi.org (có thể để trống nếu chỉ dùng RSS)
NEWS_API_KEY=

# RSS URLs
# Danh sách feed, ngăn cách bằng dấu phẩy
# Ví dụ: https://vnexpress.net/rss/tin-moi-nhat.rss,https://techcrunch.com/feed/
RSS_URLS=https://vnexpress.net/rss/tin-moi-nhat.rss,https://techcrunch.com/feed/

# Scheduler time slots (24h)
# Danh sách giờ đăng mỗi ngày, ngăn cách bằng dấu phẩy
# Ví dụ: 07:00,11:30,20:00
POSTING_TIMES=07:00,11:30,20:00

# Flask dashboard
# FLASK_PORT: cổng chạy web dashboard
FLASK_PORT=5000

# FLASK_DEBUG: true/false
FLASK_DEBUG=false

# Optional runtime settings
CLAUDE_MODEL=claude-3-5-sonnet-latest
NEWS_KEYWORD=technology
NEWS_LANGUAGE=en
NEWS_PAGE_SIZE=10
DB_PATH=data/fb_page_manager.db
LOG_LEVEL=INFO
